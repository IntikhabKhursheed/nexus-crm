{
  "name": "nexuscrm",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm run build:server && npm run build:client",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "start:client": "npm --prefix client run start",
    "start:server": "npm --prefix server run start",
    "lint": "npm run lint:client",
    "lint:client": "npm --prefix client run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5"
  }
}
