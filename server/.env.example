NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
CLIENT_ORIGIN=http://localhost:3000

# AI (any one of these keys works)
GROK_API=
GROK_API_KEY=
XAI_API_KEY=

# Auth - use long random strings in production
JWT_ACCESS_SECRET=your-long-random-access-secret
JWT_REFRESH_SECRET=your-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Stripe (test keys for local dev)
STRIPE_SECRET_KEY=your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Email (optional - weekly digest)
GMAIL_USER=
GMAIL_APP_PASSWORD=
WEEKLY_DIGEST_FROM=
