NODE_ENV=development
PORT=5000
# Include the database name before the query string (e.g. /nexuscrm)
MONGODB_URI=mongodb+srv://<username>:<password>@nexuscrm.zoqacwc.mongodb.net/nexuscrm?retryWrites=true&w=majority&appName=NexusCRM
CLIENT_ORIGIN=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Groq API (https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Auth - use long random strings in production
JWT_ACCESS_SECRET=your-long-random-access-secret
JWT_REFRESH_SECRET=your-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Stripe (test keys for local dev)
STRIPE_SECRET_KEY=your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_FREE_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Email (optional - weekly digest)
GMAIL_USER=
GMAIL_APP_PASSWORD=
WEEKLY_DIGEST_FROM=
